# Search providers
TAVILY_API_KEY=
SERPAPI_API_KEY=

# LLM endpoints — all OpenAI-compatible
LOCAL_API_KEY=EMPTY
CLOUD_API_KEY=EMPTY
OPENAI_API_KEY=

# ReMe (memory layer) LLM credentials.
# ReMe needs an OpenAI-compatible LLM for its summary/personal/task
# flows. Resolution order in reme_adapter._build_reme_args:
#   1. REME_LLM_API_KEY / REME_LLM_API_BASE / REME_LLM_MODEL — explicit override
#   2. DEEPSEEK_API_KEY                                       — auto-routes to deepseek.com
#   3. OPENAI_API_KEY                                         — default
DEEPSEEK_API_KEY=
# REME_LLM_API_KEY=
# REME_LLM_API_BASE=
# REME_LLM_MODEL=

# ReMe embedding endpoint. The LLM endpoint above doesn't always serve
# `/v1/embeddings` (vLLM serving a causal LM does not; DeepSeek's
# chat API does not). ReMe's summary flows require embeddings, so
# point these at an embedding-capable endpoint. Recommended:
#   REME_EMBEDDING_API_BASE=https://api.openai.com/v1
#   REME_EMBEDDING_API_KEY=$OPENAI_API_KEY
# with `embedding_model.default.model_name` set to text-embedding-3-small
# (cheap, reliable). Alternatively run a second vLLM serving BGE-M3.
# REME_EMBEDDING_API_KEY=   # defaults to LLM key
# REME_EMBEDDING_API_BASE=  # defaults to LLM base

# Optional overrides
DR_DATA_DIR=./data
DR_CONFIG=./config/config.local.yaml
